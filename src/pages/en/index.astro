---
import HomePage from '../../components/HomePage.astro';

const details = [
  { label: 'Date', value: 'Beginning of 2027' },
  { label: 'Place', value: 'Cuenca, Ecuador' },
  { label: 'Style', value: 'Airy, romantic, elegant' },
];
---

<HomePage
  lang="en"
  title="Carlos & Sofia | A celebration is coming"
  description="An elegant wedding site for Carlos and Sofia. More details coming soon."
  nav={{ story: 'Story', details: 'Details', journal: 'Journal', contact: 'RSVP' }}
  language={{ label: 'Language selector', current: 'EN', other: 'ES', otherHref: '/' }}
  hero={{
    eyebrow: 'With joy we invite you to celebrate the wedding of',
    firstName: 'Carlos',
    conjunction: 'and',
    secondName: 'Sofia',
    date: 'Beginning of 2027',
    location: 'Cuenca, Ecuador',
    lede:
      'We are preparing a calm, heartfelt celebration in the heart of the Andes. Soon we will share the exact date, travel guidance, and every detail for joining us.',
    primary: 'RSVP by email',
    secondary: 'View details',
  }}
  photo={{
    alt: 'Carlos and Sofia smiling together at sunset.',
  }}
  details={details}
  story={{
    eyebrow: 'The celebration',
    title: 'A minimal, warm invitation filled with light.',
    cards: [
      {
        title: 'The ceremony',
        body:
          'An intimate and elegant gathering with a clean aesthetic: soft whites, mint details, light florals, and plenty of breathing room.',
      },
      {
        title: 'The city',
        body:
          'Cuenca inspires us with its courtyards, domes, historic streets, and gentle light that we hope to share with family and friends.',
      },
      {
        title: 'The journal',
        body:
          'We will use the blog for practical notes, memories, travel recommendations, and updates as the celebration gets closer.',
      },
    ],
  }}
  contact={{
    eyebrow: 'RSVP and contact',
    title: 'Write to us to receive upcoming updates.',
    body:
      'For now this site does not collect personal data. To confirm interest, ask questions, or request more information, you can write to us directly by email.',
    button: 'Email Carlos and Sofia',
    email: 'socharlex@gmail.com',
  }}
  footer="Made with care for what is coming."
/>
