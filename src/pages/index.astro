---
import HomePage from '../components/HomePage.astro';

const details = [
  { label: 'Celebración', value: 'Inicios de 2027' },
  { label: 'Lugar', value: 'Cuenca, Ecuador' },
  { label: 'Estilo', value: 'Cálido, eterno, elegante' },
];
---

<HomePage
  lang="es"
  title="Carlos & Sofia | Una celebración está por venir"
  description="Sitio elegante de boda para Carlos y Sofia. Más detalles próximamente."
  nav={{ story: 'Historia', details: 'Detalles', journal: 'Diario' }}
  language={{ label: 'Selector de idioma', current: 'ES', other: 'EN', otherHref: '/en/' }}
  hero={{
    eyebrow: 'Reserva la temporada',
    headline: 'Carlos & Sofia',
    lede:
      'Una celebración en el corazón de los Andes, inspirada en patios históricos, salones a la luz de las velas, mesas familiares y la elegancia serena de una noche inolvidable.',
    primary: 'Ver los primeros detalles',
    secondary: 'Leer el diario',
  }}
  photo={{
    kicker: 'Con amor',
    title: 'Más detalles próximamente',
    body:
      'Estamos preparando este espacio para compartir fechas, notas de viaje, detalles del lugar y los momentos que queremos vivir junto a las personas más cercanas a nosotros.',
    alt: 'Carlos y Sofia sonriendo juntos al atardecer.',
  }}
  details={details}
  story={{
    eyebrow: 'La sensación',
    title: 'Romance colonial, luz suave y una mesa llena de familia.',
    cards: [
      {
        title: 'Calidez histórica',
        body:
          'Cielos ornamentales, balcones tallados, luz de velas y texturas antiguas marcan la dirección visual del sitio.',
      },
      {
        title: 'Elegancia natural',
        body:
          'Verdes profundos, lino, flores marfil, tonos champagne y detalles en oro antiguo mantienen una paleta suave y romántica.',
      },
      {
        title: 'Un diario vivo',
        body:
          'El blog reunirá actualizaciones, recuerdos, recomendaciones y notas prácticas conforme se acerque la celebración.',
      },
    ],
  }}
  contact={{
    eyebrow: 'Contacto',
    title: 'Un lugar refinado para cada detalle importante.',
    body:
      'Si deseas comunicarte con nosotros o pedir más información, puedes escribirnos directamente por correo. Iremos agregando nuevos detalles conforme estén listos para compartir.',
    button: 'Escribir por correo',
    email: 'socharlex@gmail.com',
  }}
  footer="Hecho con cariño para lo que viene."
/>
