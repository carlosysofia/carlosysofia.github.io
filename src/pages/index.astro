---
import HomePage from '../components/HomePage.astro';

const details = [
  { label: 'Fecha', value: 'Inicios de 2027' },
  { label: 'Lugar', value: 'Cuenca, Ecuador' },
  { label: 'Estilo', value: 'Ligero, romántico, elegante' },
];
---

<HomePage
  lang="es"
  title="Carlos & Sofia | Una celebración está por venir"
  description="Sitio elegante de boda para Carlos y Sofia. Más detalles próximamente."
  nav={{ story: 'Historia', details: 'Detalles', journal: 'Diario', contact: 'RSVP' }}
  language={{ label: 'Selector de idioma', current: 'ES', other: 'EN', otherHref: '/en/' }}
  hero={{
    eyebrow: 'Con alegría invitamos a celebrar la boda de',
    firstName: 'Carlos',
    conjunction: 'and',
    secondName: 'Sofia',
    date: 'Inicios de 2027',
    location: 'Cuenca, Ecuador',
    lede:
      'Estamos preparando una celebración serena y llena de cariño en el corazón de los Andes. Pronto compartiremos la fecha exacta, guía de viaje y todos los detalles para acompañarnos.',
    primary: 'Confirmar por correo',
    secondary: 'Ver detalles',
  }}
  photo={{
    alt: 'Carlos y Sofia sonriendo juntos al atardecer.',
  }}
  details={details}
  story={{
    eyebrow: 'La celebración',
    title: 'Una invitación minimalista, cálida y llena de luz.',
    cards: [
      {
        title: 'La ceremonia',
        body:
          'Un encuentro íntimo y elegante con una estética limpia: blancos suaves, detalles en menta, flores claras y mucho espacio para respirar.',
      },
      {
        title: 'La ciudad',
        body:
          'Cuenca nos inspira con sus patios, cúpulas, calles históricas y una luz tranquila que queremos compartir con familia y amigos.',
      },
      {
        title: 'El diario',
        body:
          'Usaremos el blog para publicar notas útiles, recuerdos, recomendaciones de viaje y actualizaciones conforme se acerque la celebración.',
      },
    ],
  }}
  contact={{
    eyebrow: 'RSVP y contacto',
    title: 'Escríbenos para recibir las próximas novedades.',
    body:
      'Por ahora este sitio no recopila datos personales. Para confirmar interés, hacer preguntas o pedir más información, puedes escribirnos directamente por correo.',
    button: 'Escribir a Carlos y Sofia',
    email: 'socharlex@gmail.com',
  }}
  footer="Hecho con cariño para lo que viene."
/>
