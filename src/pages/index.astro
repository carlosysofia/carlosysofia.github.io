---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Carlos & Sofía" description="Carlos & Sofía — Early 2027, Cuenca - Ecuador.">
  <main class="wedding-page" aria-labelledby="title">
    <section class="card" aria-label="Wedding announcement">
      <div class="floral floral-top" aria-hidden="true"></div>
      <h1 id="title"><em>Carlos &amp; Sofía</em></h1>
      <div class="divider" aria-hidden="true"><span></span></div>
      <p class="date">Early 2027</p>
      <p class="place">Cuenca - Ecuador</p>
      <div class="floral floral-bottom" aria-hidden="true"></div>
    </section>
  </main>
</BaseLayout>

<style>
  .wedding-page {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: clamp(1.25rem, 4vw, 4rem);
    position: relative;
    isolation: isolate;
  }

  .wedding-page::before {
    content: '';
    position: absolute;
    inset: clamp(0.8rem, 2vw, 1.5rem);
    border: 1px solid rgba(184, 144, 94, 0.22);
    pointer-events: none;
    z-index: -1;
  }

  .card {
    width: min(760px, 100%);
    min-height: min(82svh, 760px);
    display: grid;
    align-content: center;
    justify-items: center;
    gap: clamp(0.8rem, 2vw, 1.2rem);
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 7vw, 5rem);
    position: relative;
    overflow: hidden;
    text-align: center;
    background:
      linear-gradient(rgba(255, 250, 243, 0.91), rgba(255, 250, 243, 0.91)),
      radial-gradient(circle at center, rgba(184, 144, 94, 0.16), transparent 22rem);
    border: 1px solid rgba(184, 144, 94, 0.32);
    box-shadow: 0 34px 90px rgba(74, 51, 45, 0.18), 0 8px 28px rgba(74, 51, 45, 0.08);
  }

  .card::before,
  .card::after {
    content: '';
    position: absolute;
    inset: 1rem;
    pointer-events: none;
  }

  .card::before {
    border: 1px solid rgba(184, 144, 94, 0.28);
  }

  .card::after {
    inset: 1.65rem;
    border: 1px solid rgba(131, 147, 111, 0.2);
  }

  .kicker {
    margin: 0;
    color: var(--gold);
    font-size: clamp(0.78rem, 1.8vw, 0.95rem);
    font-weight: 500;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.3rem 0 0;
    color: var(--ink);
    font-family: 'Great Vibes', 'Brush Script MT', cursive;
    font-size: clamp(4.3rem, 15vw, 9.8rem);
    font-weight: 400;
    line-height: 0.86;
    text-shadow: 0 10px 32px rgba(74, 51, 45, 0.1);
  }

  h1 em {
    font-style: italic;
  }

  .divider {
    width: min(18rem, 58vw);
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: clamp(0.55rem, 2vw, 1.2rem) 0;
    color: var(--gold);
  }

  .divider::before,
  .divider::after {
    content: '';
    height: 1px;
    flex: 1;
    background: currentColor;
    opacity: 0.48;
  }

  .divider span {
    width: 0.55rem;
    height: 0.55rem;
    border: 1px solid currentColor;
    transform: rotate(45deg);
    opacity: 0.72;
  }

  .date,
  .place {
    margin: 0;
  }

  .date {
    color: var(--olive);
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .place {
    color: var(--soft);
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .floral {
    position: absolute;
    width: clamp(10rem, 27vw, 15rem);
    height: clamp(10rem, 27vw, 15rem);
    opacity: 0.18;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 0%, var(--sage) 0 8%, transparent 9%),
      radial-gradient(ellipse at 30% 34%, var(--sage) 0 8%, transparent 9%),
      radial-gradient(ellipse at 70% 34%, var(--sage) 0 8%, transparent 9%),
      radial-gradient(ellipse at 42% 62%, var(--gold) 0 7%, transparent 8%),
      radial-gradient(ellipse at 58% 62%, var(--gold) 0 7%, transparent 8%);
    background-size: 42% 42%;
    background-repeat: no-repeat;
  }

  .floral-top {
    top: -2.8rem;
    left: -2.8rem;
    transform: rotate(-22deg);
  }

  .floral-bottom {
    right: -2.8rem;
    bottom: -2.8rem;
    transform: rotate(158deg);
  }

  @media (max-width: 560px) {
    .card {
      min-height: 78svh;
    }

    .place {
      letter-spacing: 0.14em;
    }
  }
</style>
