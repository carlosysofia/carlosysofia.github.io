---
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Carlos & Sofía',
  description = 'Carlos & Sofía — Early 2027, Cuenca - Ecuador.',
  lang = 'en',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f7ede0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,500&family=Great+Vibes&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --paper: #f8efe4;
    --ivory: #fffaf3;
    --blush: #ead2ca;
    --sage: #83936f;
    --olive: #58664d;
    --gold: #b8905e;
    --ink: #4a332d;
    --soft: rgba(74, 51, 45, 0.64);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    min-height: 100svh;
    color: var(--ink);
    background:
      radial-gradient(circle at 10% 15%, rgba(234, 210, 202, 0.85), transparent 21rem),
      radial-gradient(circle at 85% 18%, rgba(184, 144, 94, 0.22), transparent 20rem),
      radial-gradient(circle at 15% 85%, rgba(131, 147, 111, 0.3), transparent 24rem),
      linear-gradient(135deg, #fbf4ec 0%, var(--paper) 45%, #efe0d5 100%);
    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  }

  body::before,
  body::after {
    content: '';
    position: fixed;
    pointer-events: none;
    border-radius: 999px;
    filter: blur(1px);
  }

  body::before {
    width: 36rem;
    height: 36rem;
    right: -16rem;
    top: -14rem;
    background: rgba(131, 147, 111, 0.18);
  }

  body::after {
    width: 30rem;
    height: 30rem;
    left: -15rem;
    bottom: -14rem;
    background: rgba(184, 144, 94, 0.16);
  }
</style>
