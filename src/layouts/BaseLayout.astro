---
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Carlos & Sofia',
  description = 'A warm, elegant celebration for Carlos and Sofia.',
  lang = 'es',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta name="theme-color" content="#14382c" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --ivory: #fbf5ea;
    --warm-ivory: #f5ead8;
    --champagne: #e8d2a4;
    --gold: #b98b45;
    --green: #14382c;
    --green-soft: #2f5949;
    --terracotta: #a95f3e;
    --ink: #2e241d;
    --muted: #756553;
    --veil: rgba(255, 250, 241, 0.78);
    --shadow: 0 24px 80px rgba(46, 36, 29, 0.18);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--ivory);
  }

  body {
    margin: 0;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(185, 139, 69, 0.2), transparent 34rem),
      radial-gradient(circle at bottom right, rgba(20, 56, 44, 0.18), transparent 32rem),
      var(--ivory);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.6;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.22;
    background-image:
      linear-gradient(rgba(185, 139, 69, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(185, 139, 69, 0.08) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black, transparent 78%);
  }

  a {
    color: inherit;
  }

  .serif {
    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
    font-weight: 500;
    letter-spacing: -0.035em;
  }

  .eyebrow {
    display: inline-flex;
    gap: 0.65rem;
    align-items: center;
    color: var(--gold);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .eyebrow::before,
  .eyebrow::after {
    content: '';
    width: 2.4rem;
    height: 1px;
    background: currentColor;
  }

  .container {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0.85rem 1.25rem;
    border: 1px solid rgba(185, 139, 69, 0.6);
    border-radius: 999px;
    background: var(--green);
    color: white;
    text-decoration: none;
    font-weight: 800;
    letter-spacing: 0.04em;
    box-shadow: 0 12px 34px rgba(20, 56, 44, 0.24);
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
    background: #1d4a3c;
    box-shadow: 0 16px 44px rgba(20, 56, 44, 0.3);
  }

  .button.secondary {
    background: rgba(255, 250, 241, 0.72);
    color: var(--green);
    border-color: rgba(20, 56, 44, 0.22);
    box-shadow: none;
  }

  .panel {
    border: 1px solid rgba(185, 139, 69, 0.24);
    border-radius: 2rem;
    background: var(--veil);
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  @media (max-width: 760px) {
    .eyebrow::before,
    .eyebrow::after {
      width: 1.2rem;
    }
  }
</style>
