---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  lang?: 'es' | 'en';
  title?: string;
  description?: string;
}

const {
  lang = 'en',
  title = 'Carlos & Sofía',
  description = 'Carlos and Sofía — Beginning of 2027, Cuenca.',
} = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang}>
  <main class="simple-page" aria-labelledby="site-title">
    <img
      class="portrait"
      src="/carlos-sofia.jpg"
      alt="Carlos and Sofía smiling together at sunset."
      loading="eager"
      fetchpriority="high"
    />

    <section class="card" aria-label="Wedding announcement">
      <h1 id="site-title">Carlos <span>&</span> Sofía</h1>
      <p>Beginning of 2027</p>
      <p>Cuenca</p>
    </section>
  </main>
</BaseLayout>

<style>
  .simple-page {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 3rem);
    background:
      linear-gradient(rgba(20, 56, 44, 0.34), rgba(20, 56, 44, 0.34)),
      radial-gradient(circle at top left, rgba(232, 210, 164, 0.26), transparent 34rem),
      var(--paper);
  }

  .portrait {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    filter: saturate(0.9) contrast(0.96) brightness(0.72) sepia(0.08);
  }

  .card {
    position: relative;
    z-index: 1;
    width: min(760px, 100%);
    padding: clamp(2.5rem, 8vw, 5.5rem) clamp(1.5rem, 7vw, 4.5rem);
    border: 1px solid rgba(232, 210, 164, 0.48);
    border-radius: 2rem;
    background: rgba(255, 250, 241, 0.86);
    box-shadow: 0 30px 90px rgba(20, 56, 44, 0.32);
    text-align: center;
    backdrop-filter: blur(14px);
  }

  .card::before,
  .card::after {
    content: '';
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(185, 139, 69, 0.32);
    border-radius: 1.45rem;
    pointer-events: none;
  }

  .card::after {
    inset: 1.65rem;
    border-color: rgba(20, 56, 44, 0.16);
  }

  h1 {
    margin: 0;
    color: var(--green);
    font-family: var(--serif);
    font-size: clamp(4rem, 13vw, 9rem);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 0.9;
  }

  h1 span {
    color: var(--gold);
    font-family: var(--script);
    font-size: 0.82em;
    font-weight: 400;
    letter-spacing: 0;
  }

  p {
    margin: 1.25rem 0 0;
    color: var(--ink);
    font-family: var(--serif);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  p + p {
    margin-top: 0.55rem;
    color: var(--muted);
    font-family: var(--sans);
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    font-weight: 800;
  }

  @media (max-width: 520px) {
    .simple-page {
      padding: 1rem;
    }

    .card {
      border-radius: 1.5rem;
    }

    .card::before,
    .card::after {
      display: none;
    }
  }
</style>
