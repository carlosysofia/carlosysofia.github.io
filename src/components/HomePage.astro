---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  lang?: 'es' | 'en';
  title?: string;
  description?: string;
}

const {
  lang = 'en',
  title = 'Carlos & Sofía',
  description = 'Carlos and Sofía — Beginning of 2027, Cuenca.',
} = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang}>
  <main class="announcement-page" aria-labelledby="site-title">
    <article class="announcement-card" aria-label="Wedding announcement">
      <figure class="photo-panel">
        <img
          src="/carlos-sofia.jpg"
          alt="Carlos and Sofía smiling together at sunset."
          loading="eager"
          fetchpriority="high"
        />
      </figure>

      <section class="info-panel">
        <div class="ornament ornament-left" aria-hidden="true"></div>
        <div class="ornament ornament-right" aria-hidden="true"></div>

        <h1 id="site-title">
          <span>Carlos</span>
          <em>and</em>
          <span>Sofía</span>
        </h1>

        <p class="date">Beginning of 2027</p>
        <p class="place">Cuenca</p>
      </section>
    </article>
  </main>
</BaseLayout>

<style>
  .announcement-page {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 3rem);
    background:
      radial-gradient(circle at top left, rgba(185, 139, 69, 0.18), transparent 32rem),
      radial-gradient(circle at bottom right, rgba(20, 56, 44, 0.16), transparent 34rem),
      linear-gradient(180deg, #efe1ca, var(--paper) 42%, #f6eddf);
  }

  .announcement-card {
    width: min(980px, 100%);
    margin: 0;
    border: 1px solid rgba(95, 70, 42, 0.28);
    background: #fffaf1;
    box-shadow: 0 30px 90px rgba(46, 36, 29, 0.22);
  }

  .photo-panel {
    position: relative;
    height: clamp(21rem, 55vw, 38rem);
    margin: 0;
    overflow: hidden;
    border-bottom: 1px solid rgba(95, 70, 42, 0.22);
    background: var(--mist);
  }

  .photo-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 250, 241, 0.08), rgba(20, 56, 44, 0.16)),
      linear-gradient(90deg, rgba(46, 36, 29, 0.16), transparent 28%, transparent 72%, rgba(46, 36, 29, 0.14));
    pointer-events: none;
  }

  .photo-panel img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    filter: saturate(0.9) contrast(0.95) brightness(0.96) sepia(0.08);
  }

  .info-panel {
    position: relative;
    min-height: clamp(22rem, 39vw, 30rem);
    padding: clamp(3.1rem, 7vw, 5.3rem) clamp(1.4rem, 7vw, 5rem) clamp(3rem, 7vw, 5rem);
    background:
      linear-gradient(rgba(255, 250, 241, 0.94), rgba(255, 250, 241, 0.94)),
      radial-gradient(circle at center, rgba(232, 210, 164, 0.25), transparent 25rem);
    text-align: center;
  }

  .info-panel::before,
  .info-panel::after {
    content: '';
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(185, 139, 69, 0.24);
    pointer-events: none;
  }

  .info-panel::after {
    inset: 1.55rem;
    border-color: rgba(20, 56, 44, 0.12);
  }

  .ornament {
    position: absolute;
    top: 1.55rem;
    width: clamp(3.2rem, 9vw, 5.4rem);
    height: clamp(3.2rem, 9vw, 5.4rem);
    color: rgba(185, 139, 69, 0.45);
    pointer-events: none;
  }

  .ornament-left {
    left: 1.55rem;
  }

  .ornament-right {
    right: 1.55rem;
    transform: scaleX(-1);
  }

  .ornament::before,
  .ornament::after {
    content: '';
    position: absolute;
    border-color: currentColor;
  }

  .ornament::before {
    inset: 0;
    border-top: 1px solid;
    border-left: 1px solid;
  }

  .ornament::after {
    top: 0.65rem;
    left: 0.65rem;
    width: 60%;
    height: 60%;
    border-top: 1px solid;
    border-left: 1px solid;
    transform: rotate(45deg);
    transform-origin: top left;
  }

  h1 {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.05rem;
    margin: 0;
    color: #8d9291;
    font-family: var(--serif);
    font-size: clamp(3.2rem, 9vw, 6.8rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 0.92;
    text-transform: uppercase;
  }

  h1 em {
    color: rgba(185, 139, 69, 0.72);
    font-family: var(--script);
    font-size: clamp(2.2rem, 6vw, 4.8rem);
    font-style: normal;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.82;
    text-transform: none;
  }

  .date,
  .place {
    position: relative;
    z-index: 1;
    margin: 1.9rem 0 0;
    color: rgba(185, 139, 69, 0.78);
    font-family: var(--script);
    font-size: clamp(1.7rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .place {
    margin-top: 0.7rem;
    color: var(--green);
    font-family: var(--serif);
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  @media (max-width: 620px) {
    .announcement-page {
      padding: 0;
      align-items: stretch;
    }

    .announcement-card {
      min-height: 100svh;
      border-inline: 0;
    }

    .photo-panel {
      height: 48svh;
    }

    .info-panel {
      min-height: 52svh;
      display: grid;
      align-content: center;
      padding-inline: 1.25rem;
    }

    .info-panel::before,
    .info-panel::after {
      inset-inline: 0.75rem;
    }

    .ornament {
      top: 1.1rem;
    }

    .ornament-left {
      left: 1.1rem;
    }

    .ornament-right {
      right: 1.1rem;
    }
  }
</style>
